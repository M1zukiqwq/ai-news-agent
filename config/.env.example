# ============================================
# AI News Agent 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================

# AI Model API Key (支持 Kimi/Gemini/OpenAI 等)
AI_API_KEY=your_api_key_here

# 邮件发送配置
EMAIL_SENDER=your_email@qq.com
EMAIL_PASSWORD=your_email_authorization_code
EMAIL_RECIPIENT=recipient@example.com